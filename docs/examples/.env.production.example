# ══════════════════════════════════════════════════════════
# 完整的生产环境配置示例
# 部署到：76.13.218.203:22
# 域名：ai.a889.cloud
# ══════════════════════════════════════════════════════════

# ── 必填配置 ──────────────────────────────────────────────
# Anthropic API Key（从 console.anthropic.com 获取）
ANTHROPIC_API_KEY=sk-ant-api03-你的API密钥

# ── 服务配置 ──────────────────────────────────────────────
PORT=8080
APP_ENV=production              # production | development
LOG_LEVEL=info                  # debug | info | warn | error
LOG_DIR=/var/log/moderation     # 日志存放目录

# ── API 配置 ──────────────────────────────────────────────
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
API_TIMEOUT=10              # 单次请求超时（秒）
MAX_RETRIES=2               # 失败重试次数

# ── 缓存配置 ──────────────────────────────────────────────
CACHE_DRIVER=redis          # memory | redis（生产推荐 redis）
CACHE_TTL=3600              # 缓存时长（秒），3600=1小时
REDIS_ADDR=127.0.0.1:6379
REDIS_PASS=密码-如果有的话-没有则留空
REDIS_DB=0
REDIS_PREFIX=mod:

# ── API 鉴权配置 ──────────────────────────────────────────
# 生产环境强烈建议启用！
ENABLE_AUTH=true

# 各项目的接入密钥，逗号分隔
# 格式：项目ID|密钥|速率限制(请求/分钟)
# 例如：forum_service|sk-proj-forum-a-k3j9x2m1|300
ALLOWED_KEYS=forum_service|sk-proj-forum-a-k3j9x2m1|300,bbs_service|sk-proj-bbs-b-p8q4w7n5|200,community|sk-proj-community-c-r6t2y9|500

# ── 审计和监控配置 ────────────────────────────────────────
# 启用审计日志（记录所有 API 调用和认证尝试）
ENABLE_AUDIT=true
AUDIT_LOG_DIR=/var/log/moderation/audit

# 启用详细监控指标
ENABLE_METRICS=true
METRICS_PORT=9090           # Prometheus 指标端口

# ── 安全配置 ──────────────────────────────────────────────
# 请求签名验证（额外的安全层）
ENABLE_SIGNATURE_VERIFICATION=false    # 可选：需要客户端配合
REQUEST_SIGNATURE_HEADER=X-Signature
REQUEST_TIMESTAMP_HEADER=X-Timestamp
REQUEST_TIMESTAMP_TOLERANCE=300        # 时间差容限（秒）

# 允许的来源（CORS）
ALLOW_ORIGINS=https://ai.a889.cloud,https://forum.a889.cloud
