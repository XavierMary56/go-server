# ══════════════════════════════════════════════════════════
# .env.example — 复制为 .env 后填入真实值
# cp .env.example .env
# ══════════════════════════════════════════════════════════

# ── 必填 ──────────────────────────────────────────────────
# Anthropic API Key（从 console.anthropic.com 获取）
ANTHROPIC_API_KEY=sk-ant-api03-你的密钥

# ── 服务配置 ──────────────────────────────────────────────
PORT=8080
APP_ENV=production          # production | development
LOG_LEVEL=info              # debug | info | warn | error
LOG_DIR=./logs

# ── API 配置 ──────────────────────────────────────────────
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
API_TIMEOUT=10              # 单次请求超时（秒）
MAX_RETRIES=2               # 失败重试次数

# ── 缓存配置 ──────────────────────────────────────────────
CACHE_DRIVER=memory         # memory | redis
CACHE_TTL=60                # 缓存时长（秒），0 = 禁用
REDIS_ADDR=127.0.0.1:6379
REDIS_PASS=
REDIS_DB=0
REDIS_PREFIX=mod:

# ── 鉴权配置 ──────────────────────────────────────────────
# 内网部署可关闭；生产环境建议开启
ENABLE_AUTH=false
# 各项目的接入密钥，逗号分隔（ENABLE_AUTH=true 时生效）
ALLOWED_KEYS=proj_forum_a_k3j9x2m1,proj_bbs_b_p8q4w7n5,proj_community_c_r6t2y9
