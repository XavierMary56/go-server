# ══════════════════════════════════════════════════════════
# 生产环境配置模板
# 复制此文件为 .env 并填入真实值：cp .env.production .env
# 部署地址：76.13.218.203  域名：ai.a889.cloud
# ══════════════════════════════════════════════════════════

# ── 必填（至少配置一个 Provider 的 Key）─────────────────────
# Anthropic API Key（从 console.anthropic.com 获取）
# 注意：现在可在后台"Anthropic Keys"Tab 添加多个 Key 做负载均衡
# 此处填写一个默认 Key 用于服务启动；后续可在后台继续添加
ANTHROPIC_API_KEY=sk-ant-api03-你的API密钥

# OpenAI API Key（可选，从 platform.openai.com 获取）
# 配置后支持 gpt-4o / gpt-4o-mini 等模型，后台"OpenAI Keys"Tab 管理多 Key
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Grok (xAI) API Key（可选，从 console.x.ai 获取）
# 配置后支持 grok-3 / grok-3-mini 等模型，后台"Grok Keys"Tab 管理多 Key
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions

# ── 服务配置 ──────────────────────────────────────────────
PORT=8080
APP_ENV=production          # production | development
LOG_LEVEL=info              # debug | info | warn | error
LOG_DIR=/logs               # 容器内日志目录（宿主机映射 ./logs）

# ── Anthropic API 配置 ────────────────────────────────────
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01
API_TIMEOUT=10              # 单次请求超时（秒）
MAX_RETRIES=2               # 失败重试次数

# ── 缓存配置 ──────────────────────────────────────────────
CACHE_DRIVER=redis          # memory | redis（生产推荐 redis）
CACHE_TTL=3600              # 缓存时长（秒），0=禁用
REDIS_ADDR=redis:6379       # Docker Compose 内部地址
REDIS_PASS=                 # Redis 密码（无则留空）
REDIS_DB=0
REDIS_PREFIX=mod            # Redis Key 前缀（不要带冒号，代码会自动处理）

# ── 项目鉴权配置 ──────────────────────────────────────────
# 建议开启，客户端请求时在 Header 传 X-Project-Key
ENABLE_AUTH=true

# 项目密钥列表（逗号分隔，格式：项目ID|密钥|速率限制/分钟）
# 注意：开启数据库后，密钥以数据库为准，此处仅作初始导入
# 后续在后台"项目密钥"Tab 管理，无需修改此文件
ALLOWED_KEYS=91prona|proj_91prona_def456|0

# ── 后台管理配置 ──────────────────────────────────────────
# 是否启用 Admin API 和 Web 管理后台（/admin/）
ENABLE_ADMIN_API=true

# 管理员令牌（建议使用随机字符串：openssl rand -hex 24）
# 登录后台时输入此 Token
ADMIN_TOKEN=admin_20260325_91prona_console_v2

# ── 数据持久化 ────────────────────────────────────────────
# SQLite 数据库存放在容器内 /data 目录（Docker 卷持久化）
# 存储内容：项目密钥、Anthropic Keys、模型配置
# 无需配置，自动初始化

# ── 审计日志配置 ──────────────────────────────────────────
ENABLE_AUDIT=true           # 是否记录所有 API 调用审计日志
AUDIT_LOG_DIR=/logs/audit   # 审计日志目录

# ── 监控指标配置 ──────────────────────────────────────────
ENABLE_METRICS=false        # 是否暴露 Prometheus 指标
METRICS_PORT=9090           # 指标端口
