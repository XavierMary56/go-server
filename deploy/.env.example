# 服务配置
PORT=8080
APP_ENV=production
LOG_LEVEL=info

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# 数据库 (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=moderation
DB_PASS=moderation123
DB_NAME=moderation

# 鉴权与管理
ENABLE_AUTH=true
ADMIN_TOKEN=your-admin-token
ENABLE_ADMIN_API=true

# 审计与监控
ENABLE_AUDIT=true
AUDIT_LOG_DIR=logs/audit

# 缓存
CACHE_DRIVER=redis
REDIS_ADDR=localhost:6379
REDIS_DB=0